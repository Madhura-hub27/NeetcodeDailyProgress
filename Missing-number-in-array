class Solution {
    int missingNum(int arr[]) {
        Arrays.sort(arr);
        int start=1;
        int output=0;
        boolean found=false;
        for(int i=0;i<arr.length;i++,start++){
            if(arr[i]!=start){
                output=start;
                found=true;
                break;
            }
        }
        if(found==false){
            output=arr[arr.length-1]+1;
        }
        return output;
        
    }
}
